<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.CALL_PHONE"/>

    <application
        android:label="ADK"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">

            <!-- Flutter normal theme -->
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />

            <!-- Launcher -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

            <!-- ===================================================== -->
            <!-- CUSTOM SCHEME DEEP LINKS -->
            <!-- ===================================================== -->
            <!-- Handles:
                 adkpartner://signup?ref=CODE&leg=LEFT
                 adkpartner://open?type=wishlist&token=ABC123
            -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data android:scheme="adkpartner" />
            </intent-filter>

            <!-- ===================================================== -->
            <!-- SIGNUP APP LINKS -->
            <!-- ===================================================== -->
            <!-- Handles:
                 https://aslidesikisan.netlify.app/signup
                 https://www.offerlifetime.com/signup
            -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <!-- Netlify signup -->
                <data
                    android:scheme="https"
                    android:host="aslidesikisan.netlify.app"
                    android:pathPrefix="/signup" />

                <data
                    android:scheme="http"
                    android:host="aslidesikisan.netlify.app"
                    android:pathPrefix="/signup" />

                <!-- Production website signup -->
                <data
                    android:scheme="https"
                    android:host="www.offerlifetime.com"
                    android:pathPrefix="/signup" />

                <data
                    android:scheme="http"
                    android:host="www.offerlifetime.com"
                    android:pathPrefix="/signup" />
            </intent-filter>

            <!-- ===================================================== -->
            <!-- WISHLIST APP LINKS -->
            <!-- ===================================================== -->
            <!-- Handles:
                 https://aslidesikisan.netlify.app/w/ABC123
            -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <!-- Netlify wishlist -->
                <data
                    android:scheme="https"
                    android:host="aslidesikisan.netlify.app"
                    android:pathPrefix="/w/" />

                <data
                    android:scheme="http"
                    android:host="aslidesikisan.netlify.app"
                    android:pathPrefix="/w/" />
            </intent-filter>

        </activity>

        <!-- Flutter embedding -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

    </application>

    <!-- Text processing support -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>

</manifest>